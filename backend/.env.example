# Neon Postgres connection string — https://neon.tech (free tier)
DATABASE_URL="postgresql://user:password@ep-example-12345.us-east-2.aws.neon.tech/shelfmatch?sslmode=require"

PORT=4000

# This API's own public URL — used to build links (e.g. email verification) that
# need to point back at the backend itself.
API_URL="http://localhost:4000"

# Long random string used to sign JWTs, e.g. `openssl rand -base64 32`
JWT_SECRET=""

# Origin allowed to call this API (used for CORS)
FRONTEND_URL="http://localhost:3000"

# Resend — https://resend.com (free tier, no domain verification needed for
# onboarding@resend.dev). Leave RESEND_API_KEY unset to log verification links
# to the console instead of sending real email (useful for local dev).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="ShelfMatch <onboarding@resend.dev>"

# Google OAuth — https://console.cloud.google.com (free). Leave unset to disable
# "Continue with Google" (email/password auth keeps working without it).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Gemini API key — https://aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=""

# Cloudinary — https://cloudinary.com (free tier)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
